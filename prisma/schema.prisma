generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenant plan / status enums ─────────────────────────────────────────────

enum TenantPlan {
  STARTER    // ≤5 users, core modules only
  GROWTH     // ≤20 users, all modules
  ENTERPRISE // Unlimited users, custom integrations, SLA
}

enum TenantStatus {
  TRIAL      // 14-day free trial, no billing required
  ACTIVE     // Paid subscription, all features available
  SUSPENDED  // Payment failure or admin hold — read-only access
  CANCELLED  // Churned — data retained for 90 days
}

// ── Tenant — company / workspace ──────────────────────────────────────────

model Tenant {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique

  // Subscription
  plan         TenantPlan   @default(STARTER)
  status       TenantStatus @default(TRIAL)
  trialEndsAt  DateTime?    @map("trial_ends_at")
  subscribedAt DateTime?    @map("subscribed_at")
  planRenewalAt DateTime?   @map("plan_renewal_at")

  // Business identity
  industry     String?                        // GARMENTS | FABRIC | YARN | ACCESSORIES
  country      String       @default("IN")
  timezone     String       @default("Asia/Kolkata")
  currency     String       @default("INR")
  logoUrl      String?      @map("logo_url")
  website      String?
  gstin        String?                        // Company-level GSTIN
  pan          String?                        // Company PAN

  // Limits (plan-enforced)
  maxUsers     Int          @default(5)       @map("max_users")

  createdAt    DateTime     @default(now())   @map("created_at")
  updatedAt    DateTime     @updatedAt        @map("updated_at")

  users        User[]
  roles        Role[]
  config       TenantConfig[]

  @@map("tenants")
}

// ── Config category enum ──────────────────────────────────────────────────

enum ConfigCategory {
  GENERAL        // Display name, logo URL, timezone, date format
  NOTIFICATIONS  // Email alerts, WhatsApp opt-ins, escalation rules
  INTEGRATIONS   // AWS S3 bucket, Kafka topics, Interakt key aliases
  BILLING        // Invoice prefix, GST rates, payment gateway IDs
  WORKFLOW       // Auto-close rules, approval thresholds, lead times
  FEATURES       // Feature flags — enable/disable modules per tenant
}

// ── TenantConfig — per-tenant key-value configuration ─────────────────────
//
// A flat key-value store grouped by category.  The `value` column is Json
// so it can hold strings, numbers, booleans, arrays, or nested objects.
//
// Naming convention for keys: <category>.<domain>.<setting>
//   e.g.  "billing.invoice.prefix"  →  "INV"
//         "features.qc.enabled"     →  true
//         "notifications.email.poDispatched"  →  ["owner@co.in"]
//
// isPublic=true entries are safe to forward to the frontend without
// exposing sensitive integration credentials.

model TenantConfig {
  id          String         @id @default(uuid())
  tenantId    String         @map("tenant_id")
  category    ConfigCategory
  key         String                           // unique within tenant
  value       Json                             // string | number | boolean | array | object
  description String?                          // human-readable note for admin UI
  isPublic    Boolean        @default(false)   @map("is_public")
  isEncrypted Boolean        @default(false)   @map("is_encrypted") // value stored AES-256 if true
  createdAt   DateTime       @default(now())   @map("created_at")
  updatedAt   DateTime       @updatedAt        @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, category])
  @@map("tenant_config")
}

// ── Role — named permission bundle ────────────────────────────────────────
//
// System roles (tenantId = null) are seeded once and shared across all
// tenants.  Tenants may create additional custom roles (tenantId set).
//
// Permissions use resource:action syntax:
//   buyers:read      buyers:write     buyers:delete
//   suppliers:read   suppliers:write
//   orders:read      orders:confirm   orders:cancel    orders:revise
//   invoices:read    invoices:create  invoices:approve invoices:void
//   reports:read     reports:export
//   settings:read    settings:write
//   users:read       users:write      users:assign-roles
//   audit:read

model Role {
  id          String    @id @default(uuid())
  tenantId    String?   @map("tenant_id")       // null = system-wide role
  name        String                            // e.g. "OWNER", "ACCOUNTANT"
  description String?
  permissions String[]                          // ["buyers:read","orders:confirm", …]
  isSystem    Boolean   @default(false)  @map("is_system")   // system roles cannot be deleted
  isActive    Boolean   @default(true)   @map("is_active")
  createdAt   DateTime  @default(now())  @map("created_at")
  updatedAt   DateTime  @updatedAt       @map("updated_at")

  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]

  @@unique([tenantId, name])               // system roles: (null, "OWNER") is unique
  @@index([tenantId])
  @@map("roles")
}

// ── UserRole — assignment junction ───────────────────────────────────────
//
// A user can hold multiple roles within a tenant.
// The `roles String[]` on User is a denormalised cache for fast JWT reads;
// this table is the authoritative source and is reconciled on every login.

model UserRole {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  roleId       String    @map("role_id")
  tenantId     String    @map("tenant_id")     // denormalised for quick tenant-scoped queries
  assignedById String?   @map("assigned_by_id")
  assignedAt   DateTime  @default(now())  @map("assigned_at")
  expiresAt    DateTime? @map("expires_at")    // optional time-boxed access

  user         User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId],  references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId, userId])
  @@index([tenantId, roleId])
  @@map("user_roles")
}

// ── User ──────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  email            String
  name             String
  passwordHash     String    @map("password_hash")

  // Denormalised role cache — kept in sync with UserRole on every login/
  // role-assignment.  Used directly in JWT payload so the auth hot-path
  // never needs a roles join.  Always derived from UserRole — do not edit
  // this column directly; go through the UserRole table.
  roles            String[]

  isActive         Boolean   @default(true)   @map("is_active")
  isEmailVerified  Boolean   @default(false)  @map("is_email_verified")
  isMfaEnabled     Boolean   @default(false)  @map("is_mfa_enabled")
  lastLoginAt      DateTime? @map("last_login_at")
  failedLoginCount Int       @default(0)      @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")
  createdAt        DateTime  @default(now())  @map("created_at")
  updatedAt        DateTime  @updatedAt       @map("updated_at")

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  userRoles        UserRole[]
  otpCodes         OtpCode[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordReset[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// OTP codes for MFA and email verification
model OtpCode {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tenantId    String   @map("tenant_id")
  code        String   // 6-digit hashed OTP
  type        String   // MFA_LOGIN | EMAIL_VERIFY | PASSWORD_RESET
  expiresAt   DateTime @map("expires_at")
  usedAt      DateTime? @map("used_at")
  attempts    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("otp_codes")
}

// Refresh tokens — stored in DB for revocation support
model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tenantId    String   @map("tenant_id")
  tokenHash   String   @map("token_hash")  // hashed — never store raw
  expiresAt   DateTime @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Password reset tokens
model PasswordReset {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tenantId    String   @map("tenant_id")
  tokenHash   String   @map("token_hash")
  expiresAt   DateTime @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}


model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  action    String
  tableName String   @map("table_name")
  recordId  String   @map("record_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, tableName, createdAt])
  @@map("audit_log")
}



// ── Buyer domain ───────────────────────────────────────────────────────────

model Buyer {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  name         String
  country      String
  email        String?
  phone        String?
  currency     String    @default("USD")
  address      String?
  isActive     Boolean   @default(true)  @map("is_active")
  // SAP-like customer master fields
  paymentTerms String?   @map("payment_terms")  // NET30 | NET60 | NET90 | IMMEDIATE | ADVANCE
  creditLimit  Decimal?  @db.Decimal(14,2) @map("credit_limit")
  creditDays   Int?      @map("credit_days")
  taxId        String?   @map("tax_id")          // VAT/GST number for international buyers
  segment      String?                           // A | B | C  (ABC classification)
  website      String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  orders       Order[]
  invoices     Invoice[]

  @@index([tenantId])
  @@map("buyers")
}

// ── Supplier domain ────────────────────────────────────────────────────────

model Supplier {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  name          String
  gstin         String?
  email         String?
  phone         String?
  address       String?
  contactPerson String?         @map("contact_person")
  services      String[]        // FABRIC | KNITTING | DYEING | PRINTING | SEWING
  vendorScore   Float           @default(100) @map("vendor_score")
  isActive      Boolean         @default(true) @map("is_active")
  // SAP-like vendor master fields
  pan           String?                          // PAN card (India)
  paymentTerms  String?         @map("payment_terms")   // NET30 | NET60 | NET90 | IMMEDIATE | ADVANCE
  creditDays    Int?            @map("credit_days")
  bankAccount   String?         @map("bank_account")
  bankIfsc      String?         @map("bank_ifsc")
  bankName      String?         @map("bank_name")
  website       String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt      @map("updated_at")

  purchaseOrders PurchaseOrder[]
  grns           Grn[]

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  supplierId   String    @map("supplier_id")
  poNumber     String    @map("po_number")
  status       String    @default("DRAFT")
                         // DRAFT | SENT | ACKNOWLEDGED | PART_RECEIVED | CLOSED
  poDate       DateTime  @map("po_date")
  expectedDate DateTime  @map("expected_date")
  remarks      String?
  sentAt       DateTime? @map("sent_at")
  createdById  String    @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  supplier     Supplier      @relation(fields: [supplierId], references: [id])
  lines        PurchaseOrderLine[]
  grns         Grn[]

  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  poId        String  @map("po_id")
  itemId      String  @map("item_id")
  description String?
  qty         Float
  unit        String
  rate        Float
  hsnCode     String? @map("hsn_code")
  gstPct      Float   @default(18) @map("gst_pct")
  receivedQty Float   @default(0)  @map("received_qty")

  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([tenantId, poId])
  @@map("purchase_order_lines")
}

// ── GRN domain ─────────────────────────────────────────────────────────────

model Grn {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  supplierId  String    @map("supplier_id")
  poId        String?   @map("po_id")
  grnNumber   String    @map("grn_number")
  status      String    @default("DRAFT")
                        // DRAFT | POSTED | CANCELLED
  grnDate     DateTime  @map("grn_date")
  location    String    @default("MAIN")
  invoiceNo   String?   @map("invoice_no")
  remarks     String?
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  po          PurchaseOrder? @relation(fields: [poId],       references: [id])
  lines       GrnLine[]

  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@map("grns")
}

model GrnLine {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  grnId       String  @map("grn_id")
  itemId      String  @map("item_id")
  description String?
  qty         Float
  acceptedQty Float?  @map("accepted_qty")
  unit        String
  rate        Float
  hsnCode     String? @map("hsn_code")
  gstPct      Float   @default(18) @map("gst_pct")
  amount      Float

  grn         Grn     @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@index([tenantId, grnId])
  @@map("grn_lines")
}


model Item {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  code       String
  name       String
  unit       String
  category   String? // FABRIC | TRIM | PACKING | FINISHED_GOODS
  properties Json?

  boms         Bom[]          @relation("BomFinishedGood")
  bomLines     BomLine[]      @relation("BomRawMaterial")
  stockLedger  StockLedger[]
  stockBalance StockBalance[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("items")
}


// ── Order domain ───────────────────────────────────────────────────────────

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  QC_PASSED
  DISPATCHED
  CANCELLED
}

model Order {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  buyerId      String      @map("buyer_id")
  poNumber     String      @map("po_number")
  status       OrderStatus @default(DRAFT)
  deliveryDate DateTime    @map("delivery_date")
  season       String?
  remarks      String?
  // JSONB snapshot of lines (updated on every save, frozen on CONFIRM)
  linesJson    Json?       @map("lines_json")
  // Denormalized totals for fast list views
  totalQty     Int         @default(0) @map("total_qty")
  totalStyles  Int         @default(0) @map("total_styles")
  confirmedAt  DateTime?   @map("confirmed_at")
  paidAt       DateTime?   @map("paid_at")
  createdById  String      @map("created_by_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt      @map("updated_at")

  buyer         Buyer          @relation(fields: [buyerId],  references: [id])
  orderLines    OrderLine[]
  shipments     Shipment[]
  revisions     OrderRevision[]
  invoices      Invoice[]
  qcInspections QcInspection[]
  delayRisk     DelayRiskScore?

  @@unique([tenantId, poNumber])
  @@index([tenantId, status, deliveryDate])
  @@index([tenantId, buyerId])
  @@map("orders")
}

model OrderLine {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  orderId     String   @map("order_id")
  itemId      String   @map("item_id")
  styleCode   String   @map("style_code")
  colour      String?
  qty         Int
  // { "S": 100, "M": 200, "L": 150, "XL": 50 }
  sizesJson   Json     @map("sizes_json")
  unitPrice   Decimal? @db.Decimal(14,2) @map("unit_price")
  currency    String   @default("USD")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@map("order_lines")
}

model OrderRevision {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  orderId       String   @map("order_id")
  revisionNo    Int      @map("revision_no")
  // diff: { "deliveryDate": { "from": "...", "to": "..." }, ... }
  changedFields Json     @map("changed_fields")
  // full lines snapshot at time of this revision
  linesSnapshot Json?    @map("lines_snapshot")
  reason        String?
  revisedById   String   @map("revised_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, revisionNo])
  @@index([tenantId, orderId])
  @@map("order_revisions")
}

// ── Inventory domain ───────────────────────────────────────────────────────

// Bill of Materials — recipe for each finished good / style variant
model Bom {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  itemId      String   @map("item_id")      // finished good
  styleCode   String?  @map("style_code")   // optional style variant
  version     Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  remarks     String?
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  item        Item     @relation("BomFinishedGood", fields: [itemId], references: [id])
  lines       BomLine[]

  @@unique([tenantId, itemId, styleCode, version])
  @@index([tenantId, itemId])
  @@map("boms")
}

// BOM component lines — each raw material / trim needed
model BomLine {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  bomId       String  @map("bom_id")
  rawItemId   String  @map("raw_item_id")
  qty         Decimal @db.Decimal(14,4)       // qty per unit of finished good
  unit        String
  wastagePct  Float   @default(0) @map("wastage_pct")
  remarks     String?

  bom         Bom     @relation(fields: [bomId],       references: [id], onDelete: Cascade)
  rawItem     Item    @relation("BomRawMaterial", fields: [rawItemId], references: [id])

  @@index([tenantId, bomId])
  @@map("bom_lines")
}

// Stock Ledger — append-only log of every inventory movement
enum LedgerEntryType {
  GRN_IN
  ISSUE_TO_PROD
  RETURN_FROM_PROD
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  OPENING_STOCK
}

model StockLedger {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  itemId      String          @map("item_id")
  location    String          @default("MAIN")
  entryType   LedgerEntryType @map("entry_type")
  qty         Decimal         @db.Decimal(14,4)              // positive=in, negative=out
  balanceQty  Decimal         @db.Decimal(14,4) @map("balance_qty")
  rate        Decimal?        @db.Decimal(14,2)
  refType     String?         @map("ref_type")               // GRN | ORDER | ADJUSTMENT
  refId       String?         @map("ref_id")
  remarks     String?
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  item        Item            @relation(fields: [itemId], references: [id])

  @@index([tenantId, itemId, location, createdAt])
  @@map("stock_ledger")
}

// Stock Balance — materialized current balance (updated on every ledger entry)
model StockBalance {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  itemId    String   @map("item_id")
  location  String   @default("MAIN")
  onHand    Decimal  @db.Decimal(14,4) @map("on_hand")
  reserved  Decimal  @db.Decimal(14,4) @default(0)
  available Decimal  @db.Decimal(14,4)                // onHand - reserved
  updatedAt DateTime @updatedAt @map("updated_at")

  item      Item     @relation(fields: [itemId], references: [id])

  @@unique([tenantId, itemId, location])
  @@index([tenantId, itemId])
  @@map("stock_balances")
}

model Shipment {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  orderId      String    @map("order_id")
  vehicleNo    String?   @map("vehicle_no")
  ewayBillNo   String?   @map("eway_bill_no")
  dispatchedAt DateTime? @map("dispatched_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  order        Order     @relation(fields: [orderId], references: [id])

  @@index([tenantId, orderId])
  @@map("shipments")
}

// ── Invoice domain ─────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceType {
  SALES
  PURCHASE
}

enum PaymentMode {
  BANK_TRANSFER
  CHEQUE
  CASH
  UPI
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  orderId     String?       @map("order_id")
  buyerId     String?       @map("buyer_id")
  type        InvoiceType   @default(SALES)
  invoiceNo   String        @map("invoice_no")
  invoiceDate DateTime      @map("invoice_date")
  dueDate     DateTime      @map("due_date")
  subtotal    Decimal       @db.Decimal(14, 2)
  gstAmount   Decimal       @db.Decimal(14, 2) @map("gst_amount")
  total       Decimal       @db.Decimal(14, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(14, 2) @map("paid_amount")
  currency    String        @default("INR")
  irnNumber   String?       @map("irn_number")
  status      InvoiceStatus @default(DRAFT)
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  order       Order?        @relation(fields: [orderId], references: [id])
  buyer       Buyer?        @relation(fields: [buyerId], references: [id])
  lines       InvoiceLine[]
  payments    Payment[]

  @@index([tenantId, status])
  @@index([tenantId, buyerId])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  invoiceId   String  @map("invoice_id")
  description String
  hsnCode     String? @map("hsn_code")
  qty         Float
  rate        Decimal @db.Decimal(14, 2)
  gstPct      Float   @map("gst_pct")
  amount      Decimal @db.Decimal(14, 2)

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@map("invoice_lines")
}

model Payment {
  id         String      @id @default(uuid())
  tenantId   String      @map("tenant_id")
  invoiceId  String      @map("invoice_id")
  amount     Decimal     @db.Decimal(14, 2)
  mode       PaymentMode
  reference  String?
  paidAt     DateTime    @map("paid_at")
  createdAt  DateTime    @default(now()) @map("created_at")

  invoice    Invoice     @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, invoiceId])
  @@map("payments")
}

// ── QC domain (referenced by Order) ───────────────────────────────────────

model QcInspection {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  orderId     String   @map("order_id")
  styleCode   String   @map("style_code")
  inspectorId String   @map("inspector_id")
  inspType    String   @map("insp_type")
  result      String
  aqlLevel    String?  @map("aql_level")
  sampleSize  Int?     @map("sample_size")
  defectCount Int      @default(0) @map("defect_count")
  photoUrls   Json     @default("[]") @map("photo_urls")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  order       Order    @relation(fields: [orderId], references: [id])

  @@index([tenantId, orderId])
  @@map("qc_inspections")
}

// ── Delay risk (referenced by Order) ──────────────────────────────────────

model DelayRiskScore {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  orderId           String   @unique @map("order_id")
  riskScore         Float    @map("risk_score")
  riskLabel         String   @map("risk_label")
  factors           Json
  recommendedAction String?  @map("recommended_action")
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  order             Order    @relation(fields: [orderId], references: [id])

  @@map("delay_risk_scores")
}