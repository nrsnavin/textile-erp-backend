{
  "compilerOptions": {
    "module":                 "commonjs",
    "target":                 "ES2021",
    "strict":                 true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata":  true,
    "skipLibCheck":           true,
    "esModuleInterop":        true,
    "outDir":                 "./dist",
    "baseUrl":                ".",
    "incremental":            true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}